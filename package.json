{
	"name": "simlab-fkg",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun run src/lib/server/db/seeds/index.ts",
		"db:seed-laboratorium": "bun run src/lib/server/db/seeds/laboratorium.ts",
		"db:seed-dpjp": "bun run src/lib/server/db/seeds/dpjp.ts",
		"db:seed-inventaris-preparasi": "bun run src/lib/server/db/seeds/inventaris-preparasi.ts",
		"db:seed-users": "bun run src/lib/server/db/seeds/users.ts",
		"db:seed-mahasiswa": "bun run src/lib/server/db/seeds/mahasiswa.ts",
		"db:seed-logbook-templates": "bun run src/lib/server/db/seeds/logbook-templates.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"overrides": {
		"@better-auth/core": "1.5.6"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@biomejs/biome": "2.5.0",
		"@eslint/compat": "^2.0.2",
